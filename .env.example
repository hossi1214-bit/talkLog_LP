# Public canonical URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://talklog.app
# Supabase beta registration (server-only secret; never prefix it with NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=
# Resend registration confirmation email (server-only)
RESEND_API_KEY=
RESEND_FROM_EMAIL=talkLog <notice@talklog.app>
NEXT_PUBLIC_X_URL=https://x.com/your_account
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/your_account
# Optional measurement IDs; safe to leave blank until integrations are added.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
